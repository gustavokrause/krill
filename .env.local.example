# Copy to .env.local and fill in.

# SQLite file path (relative to repo root). Default: data/tasks.db
DB_PATH=data/tasks.db

# Worktrees root for tasks with has_repo=true. Default: ~/.ai-worktrees/
WORKTREES_ROOT=~/.ai-worktrees/

# Claude Code CLI pinned version (smoke-tested). Match against `claude --version`.
CLAUDE_CODE_VERSION=

# Runner mode: `real` spawns the `claude` CLI per stage (burns API tokens).
# Anything else (or unset) uses the stub runner — fast, free, deterministic for local dev/tests.
CLAUDE_RUNNER=

# MCP isolation: 1 loads ONLY krill's task MCP server into stage runs (your
# user MCP servers from ~/.claude.json are skipped). Unset: user MCP loads too.
KRILL_STRICT_MCP=

# Session continuity kill switch: 0 forces cold spawns everywhere (the
# pre-continuity behavior). Unset: implementing retries + verify runs resume
# a fresh same-model session; AI review always starts cold.
KRILL_RESUME=

# HTTP port (must match next dev/start flag).
PORT=3000
