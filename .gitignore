# local Claude Code state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# graphify outputs (regenerated from docs)
graphify-out/

# environment
.env
.env.local
.env.*.local

# node / next
# No trailing slash: also ignores the node_modules *symlink* a worktree creates
# (provisionWorktreeDeps). A dir-only pattern (node_modules/) missed it, so
# `git add -A` swept the symlink into worktree PRs — leaking the absolute path.
node_modules
.next/
out/
dist/
build/
next-env.d.ts
*.tsbuildinfo
.turbo/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# coverage
coverage/

# data / sqlite
data/
*.db
*.db-shm
*.db-wal
*.db-journal

# secrets (defensive)
*.pem
*.key

# editors
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# playwright MCP scratch (page snapshots + console logs — leaks board/project data)
.playwright-mcp/
